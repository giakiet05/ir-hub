# Environment Variables Example

# Serial port path (preferred by-id path)
BY_ID_PATH=/dev/serial/by-id/usb-Raspberry_Pi_Pico_E66428C51F9F4D33-if00

# Serial baud rate
BAUD_RATE=115200

# Directory containing preset JSON files (relative to working directory)
PRESET_DIR=./presets

# Logging level (debug, info, warn, error)
LOG_LEVEL=debug
